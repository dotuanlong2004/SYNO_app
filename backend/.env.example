# Server
PORT=3000
NODE_ENV=development

# ============================================================
# SUPABASE CONFIGURATION (Required)
# ============================================================
# 1) SUPABASE_URL:
#    Supabase Dashboard -> Settings -> API -> Project URL
#    Format: https://<project-ref>.supabase.co
SUPABASE_URL="https://<project-ref>.supabase.co"

# 2) SUPABASE_ANON_KEY:
#    Supabase Dashboard -> Settings -> API -> anon / publishable key
SUPABASE_ANON_KEY="<paste-anon-or-publishable-key-here>"

# 3) SUPABASE_SERVICE_ROLE_KEY (server-only, KHONG dua len git):
#    Supabase Dashboard -> Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY="<paste-service-role-key-here>"

# 4) Direct PostgreSQL connection for migrations / pg-boss
#    Supabase Dashboard -> Settings -> Database -> Connection string (URI)
#    Use pooler/session URI on networks without IPv6 direct DB access.
#    Example formats only:
# SUPABASE_DB_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres
# SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Attendance queue
# Development can disable this because direct DB credentials may be unavailable.
# Production should set both values below.
ENABLE_ATTENDANCE_QUEUE=false
REQUIRE_ATTENDANCE_QUEUE=false

# ============================================================
# LEGACY - Deprecated (kept for reference only)
# ============================================================
# PostgreSQL (Docker example) - Replaced by Supabase
# DATABASE_URL=postgres://postgres:123456@127.0.0.1:5433/attendance_db

# Redis (Docker example) - Replaced by PostgreSQL tables
# REDIS_URL=redis://localhost:6379

# ============================================================
# APPLICATION SETTINGS
# ============================================================
# Wall-clock for attendance windows
ATTENDANCE_TIMEZONE=Asia/Ho_Chi_Minh

# Optional hardware route protection
# Required in production. Collector must send X-Hardware-Api-Key.
# HARDWARE_API_KEY=<long-random-secret>

# HNS tenant defaults
DEFAULT_SCHOOL_ID=1
SCHOOL_ID=1

# ============================================================
# SUPABASE AUTH NOTE
# ============================================================
# SUPABASE_SERVICE_ROLE_KEY is required for admin operations (create users)
# Get it from: Supabase Dashboard > Project Settings > API > service_role key
# WARNING: Keep this secret! It bypasses RLS policies.

# Firebase Admin (for server push)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={...}

# Optional seed user values for scripts/seed-user.js
# SEED_USER_EMAIL=parent1@school.local
# SEED_USER_PASSWORD=Password@123
# SEED_USER_FULL_NAME=Default Parent
# SEED_USER_ROLE=parent

# Worker concurrency (default 20)
# ATTENDANCE_WORKER_CONCURRENCY=20
